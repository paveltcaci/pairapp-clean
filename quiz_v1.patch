+    // Resolve option labels for choice type
+    String resolveLabel(String answerId) {
+      if (!isChoice) return answerId;
+      final opt =
+          round.options.where((o) => o['id'] == answerId).firstOrNull;
+      return opt?['text'] ?? answerId;
+    }
