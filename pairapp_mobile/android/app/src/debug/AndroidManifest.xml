<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Required for Flutter tooling (hot reload, breakpoints, etc.) -->
    <uses-permission android:name="android.permission.INTERNET"/>

    <!--
      Allow cleartext HTTP traffic to Firebase Emulator Suite (10.0.2.2)
      in debug builds only. This attribute is NOT set in the main manifest
      so it has no effect on production APKs.
    -->
    <application
        android:networkSecurityConfig="@xml/network_security_config"
        android:usesCleartextTraffic="true" />
</manifest>
